<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <rect width="512" height="512" rx="80" fill="#0a0e1a"/>
  <rect width="512" height="512" rx="80" fill="url(#bg)"/>
  <defs>
    <radialGradient id="bg" cx="30%" cy="30%">
      <stop offset="0%" stop-color="#0d1f3c"/>
      <stop offset="100%" stop-color="#0a0e1a"/>
    </radialGradient>
  </defs>
  <!-- Resistor body -->
  <rect x="80" y="220" width="352" height="72" rx="16" fill="#c8b08a" stroke="#8a6a3a" stroke-width="4"/>
  <!-- Wires -->
  <line x1="0" y1="256" x2="80" y2="256" stroke="#aaa" stroke-width="8"/>
  <line x1="432" y1="256" x2="512" y2="256" stroke="#aaa" stroke-width="8"/>
  <!-- Color bands -->
  <rect x="115" y="220" width="36" height="72" rx="4" fill="#FFD700"/>
  <rect x="168" y="220" width="36" height="72" rx="4" fill="#8B008B"/>
  <rect x="221" y="220" width="36" height="72" rx="4" fill="#FF6600"/>
  <rect x="360" y="220" width="30" height="72" rx="4" fill="#C8A000"/>
  <!-- Lightning bolt -->
  <text x="256" y="180" text-anchor="middle" font-size="72" fill="#00d4ff" filter="url(#glow)">⚡</text>
  <defs>
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>
  <!-- Text -->
  <text x="256" y="360" text-anchor="middle" font-family="Arial Black, sans-serif" font-size="38" font-weight="900" fill="#00d4ff" letter-spacing="1">CALCU</text>
  <text x="256" y="400" text-anchor="middle" font-family="Arial Black, sans-serif" font-size="28" font-weight="700" fill="#00ff88" letter-spacing="2">MIREJUANCA</text>
</svg>
